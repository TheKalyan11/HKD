# Server Configuration
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
JWT_SECRET=hkd_premium_jwt_secret_108

# Redis Cache (optional — runs in passthrough mode without it)
REDIS_URL=redis://127.0.0.1:6379

# Admin Login Defaults
ADMIN_EMAIL=admin@hkd.org
ADMIN_PASSWORD=Krishna108
STAFF_EMAIL=staff@hkd.org
STAFF_PASSWORD=Staff108

# Firebase Configuration
# Paste your service account JSON contents here as a single-line string to enable live connections.
# Leave blank to automatically activate the local memory simulated Firestore fallback!
FIREBASE_SERVICE_ACCOUNT_KEY=
FIREBASE_DATABASE_URL=

# Razorpay API Credentials
# Configure to trigger real checkouts. Leave blank to run simulated offline checkout flows!
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=hkd_webhook_secret_123

# SMTP Email Configuration
# Configure host, port, and security rules. Leave blank to run local console-logged simulations!
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here
SMTP_SENDER=noreply@hkd.org

# Meta WhatsApp Cloud API Credentials
# Configure credentials. Leave blank to run local console-logged notifications!
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_TEMPLATE_LANG=en_US
